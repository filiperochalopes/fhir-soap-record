# Local default. Replace with your external MySQL URL when needed.
DATABASE_URL="mysql://clinic:clinic@localhost:3306/fhir_soap_record"
APP_PORT="3000"
DB_PORT="3306"
DB_NAME="fhir_soap_record"
DB_USER="clinic"
# Generate a strong 12-character password: python3 -c "import secrets,string; chars=string.ascii_letters+string.digits+'!@#$%&*+-_'; print(''.join(secrets.choice(chars) for _ in range(12)))"
DB_PASS="clinic"
PORT="3000"
APP_URL="http://localhost:3000"
COOKIE_NAME="clinic_token"
DRY_RUN="false"

# Import pipeline - OCR (Mistral)
MISTRAL_API_KEY=""
MISTRAL_OCR_MODEL="mistral-ocr-latest"
MISTRAL_API_BASE_URL="https://api.mistral.ai"

# Import pipeline - LM (Anthropic / LangChain ChatAnthropic compatible)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
ANTHROPIC_API_BASE_URL="https://api.anthropic.com"
ANTHROPIC_API_VERSION="2023-06-01"

CLINIC_TIMEZONE_OFFSET="-03:00"
