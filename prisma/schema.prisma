generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Patient {
  id                  Int       @id @default(autoincrement())
  name                String
  gender              String
  birthDate           DateTime? @map("birth_date") @db.Date
  isDraft             Boolean   @default(false) @map("is_draft")
  active              Boolean   @default(true)
  mergedIntoPatientId Int?      @map("merged_into_patient_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  mergedInto     Patient?        @relation("PatientMerge", fields: [mergedIntoPatientId], references: [id])
  replaces       Patient[]       @relation("PatientMerge")
  telecom        ContactPoint[]
  identifier     Identifier[]
  appointments   Appointment[]
  encounterDrafts EncounterDraft[]
  clinicalAttachments ClinicalAttachment[]
  contacts       Contact[]
  soapNotes      SoapNote[]
  narrativeNotes NarrativeNote[]
  clinicalDocumentWebhookEvents ClinicalDocumentWebhookEvent[]
}

model Contact {
  id           Int      @id @default(autoincrement())
  name         String
  relationship String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  patientId Int     @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id])
}

model ContactPoint {
  id        Int      @id @default(autoincrement())
  system    String
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  patientId Int?     @map("patient_id")
  patient   Patient? @relation(fields: [patientId], references: [id])

  @@unique([system, value, patientId])
}

model Identifier {
  id        Int      @id @default(autoincrement())
  system    String
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  patientId Int?     @map("patient_id")
  patient   Patient? @relation(fields: [patientId], references: [id])

  @@unique([system, value])
}

model Appointment {
  id              Int      @id @default(autoincrement())
  patientId       Int      @map("patient_id")
  start           DateTime
  end             DateTime
  status          String
  appointmentType String   @map("appointment_type")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  patient   Patient    @relation(fields: [patientId], references: [id])
  soapNotes SoapNote[]
}

model GeneralSetting {
  id        Int      @id @default(autoincrement())
  property  String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
}

model AuthUser {
  id        Int      @id @default(autoincrement())
  fullName  String   @map("full_name")
  crm       String
  crmUf     String   @map("crm_uf")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  tokens         AuthToken[]
  soapNotes      SoapNote[]
  narrativeNotes NarrativeNote[]
  encounterDrafts EncounterDraft[]
  clinicalAttachments ClinicalAttachment[]
  attachmentPluginExecutions AttachmentPluginExecution[]
  clinicalDocumentWebhookEvents ClinicalDocumentWebhookEvent[]
  pluginCredentials UserPluginCredential[]
  auditLogs      AuditLog[]

  @@unique([crm, crmUf])
}

model AuthToken {
  id         Int       @id @default(autoincrement())
  tokenHash  String    @map("token_hash")
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  revokedAt  DateTime? @map("revoked_at")

  userId Int      @map("user_id")
  user   AuthUser @relation(fields: [userId], references: [id])

  @@unique([tokenHash])
}

model SoapNote {
  id             Int      @id @default(autoincrement())
  patientId      Int      @map("patient_id")
  authorUserId   Int      @map("author_user_id")
  appointmentId  Int?     @map("appointment_id")
  encounteredAt  DateTime @map("encountered_at")
  subjective     String   @db.Text
  objective      String   @db.Text
  assessment     String   @db.Text
  plan           String   @db.Text
  sourceSystem   String?  @map("source_system")
  sourceRecordId String?  @map("source_record_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  clinicalAttachments ClinicalAttachment[]
  patient     Patient      @relation(fields: [patientId], references: [id])
  author      AuthUser     @relation(fields: [authorUserId], references: [id])

  @@index([appointmentId])
  @@unique([sourceSystem, sourceRecordId])
}

model NarrativeNote {
  id             Int      @id @default(autoincrement())
  patientId      Int      @map("patient_id")
  authorUserId   Int      @map("author_user_id")
  encounteredAt  DateTime @map("encountered_at")
  title          String?
  sections       Json
  sourceSystem   String?  @map("source_system")
  sourceRecordId String?  @map("source_record_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  patient Patient  @relation(fields: [patientId], references: [id])
  author  AuthUser @relation(fields: [authorUserId], references: [id])
  clinicalAttachments ClinicalAttachment[]

  @@unique([sourceSystem, sourceRecordId])
}

model EncounterDraft {
  id            Int      @id @default(autoincrement())
  patientId     Int      @map("patient_id")
  authorUserId  Int      @map("author_user_id")
  appointmentId Int?     @map("appointment_id")
  draftKey      String   @map("draft_key")
  noteType      String   @default("soap") @map("note_type")
  status        String   @default("active")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  author AuthUser @relation(fields: [authorUserId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  clinicalAttachments ClinicalAttachment[]

  @@unique([patientId, authorUserId, draftKey])
  @@index([expiresAt])
}

model ClinicalAttachment {
  id              Int      @id @default(autoincrement())
  patientId       Int      @map("patient_id")
  authorUserId    Int      @map("author_user_id")
  draftId         Int?     @map("draft_id")
  appointmentId   Int?     @map("appointment_id")
  soapNoteId      Int?     @map("soap_note_id")
  narrativeNoteId Int?     @map("narrative_note_id")
  status          String   @default("draft")
  fileName        String   @map("file_name")
  contentType     String   @map("content_type")
  byteSize        Int      @map("byte_size")
  sha256          String
  s3Bucket        String   @map("s3_bucket")
  s3Key           String   @map("s3_key")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  author AuthUser @relation(fields: [authorUserId], references: [id])
  draft EncounterDraft? @relation(fields: [draftId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  soapNote SoapNote? @relation(fields: [soapNoteId], references: [id])
  narrativeNote NarrativeNote? @relation(fields: [narrativeNoteId], references: [id])
  pluginExecutions AttachmentPluginExecution[]

  @@index([draftId])
  @@index([patientId, status])
  @@index([soapNoteId])
  @@index([narrativeNoteId])
}

model AttachmentPluginExecution {
  id                Int       @id @default(autoincrement())
  attachmentId      Int       @map("attachment_id")
  pluginId          String    @map("plugin_id")
  requestedByUserId Int       @map("requested_by_user_id")
  externalJobId     String?   @map("external_job_id")
  status            String
  summary           String?   @db.Text
  result            Json?
  error             String?   @db.Text
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  attachment ClinicalAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  requestedBy AuthUser @relation(fields: [requestedByUserId], references: [id])

  @@unique([attachmentId, pluginId])
  @@index([pluginId, status])
  @@index([requestedByUserId, status])
}

model UserPluginCredential {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  pluginId        String   @map("plugin_id")
  encryptedSecret String   @map("encrypted_secret") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pluginId])
}

model ClinicalDocumentWebhookEvent {
  id           Int       @id @default(autoincrement())
  patientId    Int       @map("patient_id")
  authorUserId Int       @map("author_user_id")
  state        String
  documentType String    @map("document_type")
  clinicalNote String    @map("clinical_note") @db.Text
  payload      Json?
  consumedAt   DateTime? @map("consumed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  patient Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  author  AuthUser @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@unique([state])
  @@index([patientId, authorUserId, consumedAt], map: "cdwe_patient_author_consumed_idx")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  category   String
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  userId Int?      @map("user_id")
  user   AuthUser? @relation(fields: [userId], references: [id])
}
